# Dockerfile for huntr-web service (Go)
# Multi-stage build, ARM64 compatible for Raspberry Pi 5

FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git

WORKDIR /build
COPY src/go.mod src/go.sum ./
RUN go mod download

COPY src/ ./
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /huntr-web ./cmd/web

# --- Runtime ---
FROM alpine:3.21

RUN apk add --no-cache ca-certificates curl && \
    adduser -D -u 1000 huntr

WORKDIR /app
COPY --from=builder /huntr-web /app/huntr-web
COPY src/templates/ /app/templates/

RUN mkdir -p /data && chown huntr:huntr /data

USER huntr
EXPOSE 5000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -sf http://localhost:5000/health || exit 1

CMD ["/app/huntr-web"]
